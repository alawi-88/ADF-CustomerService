# =============================================================================
# ADF Customer-Service POC — environment variables
# =============================================================================
# Copy to .env (which is gitignored) and fill in values for your environment.
#
#   cp .env.example .env
#   # then edit .env
#
# NEVER commit a real .env to git.
# =============================================================================

# --- Server ----------------------------------------------------------------
APP_PORT=8501
APP_LOG_LEVEL=info     # debug | info | warning | error

# --- Groq (preferred cloud LLM, fastest) -----------------------------------
# Leave empty to skip Groq and fall through to Ollama / rule engine.
GROQ_API_KEY=
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant,gemma2-9b-it

# --- Ollama (local fallback) ------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# --- Versioning + audit ----------------------------------------------------
ADF_CS_VERSION=1.1.0           # tagged version, used by docker-compose
PROMPT_VERSION=v2              # incremented when prompts change

# --- Data residency note ---------------------------------------------------
# Per slide 40 of the project briefing: "جميع البيانات داخل المملكة — لا استثناءات"
# When you flip GROQ_API_KEY on, customer text leaves the kingdom (Groq is US-hosted).
# For production, prefer Ollama-only (GROQ_API_KEY blank) until a regional LLM provider
# is approved by ADF's risk + compliance team.
